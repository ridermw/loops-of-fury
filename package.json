{
  "name": "loops-of-fury",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "check": "node --test",
    "loop:init": "node .loop/driver.mjs --init",
    "loop:check": "node .loop/check.mjs",
    "loop:verify": "node .loop/control-manifest.mjs",
    "loop:gate": "node .loop/diff-gate.mjs",
    "loop:selftest": "node .loop/driver.mjs --selftest",
    "loop:selftest-gate": "node .loop/driver.mjs --selftest-gate",
    "loop:dry": "node .loop/driver.mjs --dry",
    "loop:once": "node .loop/driver.mjs --once",
    "loop:test": "node --test .loop/tests/brain.test.mjs .loop/tests/loop.test.mjs .loop/tests/checker.test.mjs .loop/tests/secret-scan.test.mjs .loop/tests/diff-gate.test.mjs .loop/tests/push-gate.test.mjs .loop/tests/control-manifest.test.mjs .loop/tests/anchors.test.mjs",
    "loop:scan": "node .loop/secret-scan.mjs",
    "loop:pushgate": "node .loop/push-gate.mjs",
    "loop:install-hooks": "git config core.hooksPath .githooks",
    "loop:preflight": "node .loop/loop.mjs --preflight",
    "loop:run": "node .loop/loop.mjs --run"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "playwright": "1.61.0"
  }
}
